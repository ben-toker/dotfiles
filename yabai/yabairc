# ensure 5 spaces exist globally
for i in {1..5}; do
    yabai -m space --create $i 2>/dev/null
done

# Signal to refresh simplebar on space changes
yabai -m signal --add event=space_changed action="osascript -e 'tell application \"simplebar\" to refresh'"
yabai -m signal --add event=display_changed action="osascript -e 'tell application \"simplebar\" to refresh'"
#sudo yabai --load-sa

# Ensure spaces 1-5 are assigned to the MacBook (Display 1)
yabai -m space 1 --display 1
yabai -m space 2 --display 1
yabai -m space 3 --display 1
yabai -m space 4 --display 1
yabai -m space 5 --display 1

# Ensure spaces 6-10 are assigned to the External Monitor (Display 2)
yabai -m space 6 --display 2
yabai -m space 7 --display 2
yabai -m space 8 --display 2
yabai -m space 9 --display 2
yabai -m space 10 --display 2
