sudo yabai --load-sa

# Create spaces if they don't exist (e.g., ensure 5 spaces exist)
desired_spaces=5
current_spaces=$(yabai -m query --spaces | jq '. | length')

if [ "$current_spaces" -lt "$desired_spaces" ]; then
    for i in $(seq 1 $((desired_spaces - current_spaces))); do
        yabai -m space --create
    done
fi

# Signal to force BSP whenever a space is created or focused
yabai -m signal --add event=space_changed action="yabai -m space --layout bsp"
yabai -m signal --add event=display_changed action="yabai -m space --layout bsp"


# bsp or float (default: float)
yabai -m config layout bsp

# New window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child

# set focus follows mouse mode (default: off, options: off, autoraise, autofocus)
yabai -m config focus_follows_mouse off

# Mouse follows focus (the opposite of focus follows mouse)
yabai -m config mouse_follows_focus on

# hyprland feel
yabai -m config space_wrap on

#top padding
~/.config/scripts/displayresize.sh
~/.config/yabai/wallpaper.sh

# Set all padding and gaps to 20pt (default: 0)
yabai -m config top_padding 5
yabai -m config bottom_padding 5
yabai -m config left_padding   5
yabai -m config right_padding  5
yabai -m config window_gap     5


# ===== Rules ==================================
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Messages$" manage=off
yabai -m rule --add app="^Finder$" manage=off
